{
	"name": "muallim-web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"packageManager": "pnpm@11.10.0",
	"engines": {
		"node": ">=24"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "pnpm test:unit --run && pnpm test:e2e",
		"gen:api": "openapi-typescript ../muallim-api/bin/openapi.json -o src/lib/api/schema.d.ts",
		"test:e2e": "playwright test"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@fontsource-variable/inter": "^5.2.8",
		"@internationalized/date": "^3.12.2",
		"@playwright/test": "^1.61.1",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@types/node": "^24",
		"clsx": "^2.1.1",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"openapi-typescript": "^7.13.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwind-merge": "^3.6.0",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vite": "^8.0.16",
		"vitest": "^4.1.8"
	},
	"dependencies": {
		"@fontsource-variable/geist-mono": "^5.2.8",
		"@fontsource-variable/mona-sans": "^5.2.8",
		"@hugeicons/core-free-icons": "^4.2.2",
		"@hugeicons/svelte": "^1.1.4",
		"@tanstack/ai": "^0.40.0",
		"@tanstack/ai-anthropic": "^0.16.1",
		"@tanstack/ai-svelte": "^0.14.3",
		"@thisux/sveltednd": "^0.4.1",
		"openapi-fetch": "^0.17.0",
		"zod": "^4.4.3"
	}
}
