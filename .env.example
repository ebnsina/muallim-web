# AI Studio (optional). With no key the "Draft with AI" controls are simply hidden,
# so the forms work unchanged. Provider-agnostic: swap the adapter in
# src/lib/server/ai.ts for another @tanstack/ai-* driver.
#
# ANTHROPIC_API_KEY=sk-ant-...
# AI_MODEL=claude-sonnet-4-5

# The chat WebSocket connects to muallim-api directly — a different origin than
# this app, so it cannot use the httpOnly session cookie and authenticates with a
# short-lived ticket instead. This is where the browser opens that socket. In
# development it is muallim-api's own address; in production it is the wss:// URL
# the edge routes /v1/chat/ws to. PUBLIC_ so the browser can read it.
PUBLIC_CHAT_WS_URL=ws://localhost:8080
